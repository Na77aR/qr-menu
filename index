async function verifyPayment(type){
  const inputId=type==='shamcash'?'tran-id-sc':'tran-id-sy';
  const btnId='verify-btn-'+{shamcash:'sc',syriatel:'sy'}[type];
  const resId='verify-result-'+{shamcash:'sc',syriatel:'sy'}[type];
  const tranId=document.getElementById(inputId).value.trim();
  if(!tranId){showToast('أدخل رقم العملية أولاً');return;}
  const btn=document.getElementById(btnId), res=document.getElementById(resId);
  btn.textContent='⏳ جارٍ التحقق...'; btn.disabled=true; res.style.display='none';
  const resource=type==='shamcash'?'shamcash':'syriatelcash';
  const address=type==='shamcash'?CONFIG.shamcash:CONFIG.syriatel;
  try{
    const r=await fetch(`https://apisyria.com/api/v1?resource=${resource}&action=find_tx&tx=${tranId}&account_address=${address}&api_key=${CONFIG.apiKey}`);
    const data=await r.json();
    if(data.success&&data.data.found){
      const tx=data.data.transaction;
      if(parseFloat(tx.amount)>=getTotal()){
        res.className='verify-result ok';
        res.innerHTML=`✅ تم التحقق! المبلغ: ${parseFloat(tx.amount).toLocaleString()} ل.س<br><small>جارٍ الإرسال...</small>`;
        res.style.display='block';
        setTimeout(()=>{
          const label=type==='shamcash'?'شام كاش':'سيريتل كاش';
          window.open(`https://wa.me/${CONFIG.whatsapp}?text=${encodeURIComponent(buildMsg(`\n✅ *تم الدفع بـ${label}*\nرقم العملية: ${tranId}`))}`,'_blank');
          
        },1500);
      } else {
        res.className='verify-result fail'; res.innerHTML='❌ المبلغ أقل من المطلوب'; res.style.display='block';
      }
