<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>مطعم الجسري</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{--gold:#c8963e;--gold-light:#e8b86d;--bg:#0f0e0d;--bg2:#1a1814;--bg3:#1e1c18;--border:#2e2b24;--text:#f5f0e8;--muted:#a09080;--dim:#7a7060;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--text);direction:rtl;}
.app{max-width:480px;margin:0 auto;min-height:100vh;}
.page{display:none;min-height:100vh;padding-bottom:40px;}
.page.active{display:block;}
.header{background:linear-gradient(135deg,#c8963e,#e8b86d,#c8963e);padding:18px 20px 12px;text-align:center;position:sticky;top:0;z-index:50;box-shadow:0 4px 20px rgba(200,150,62,0.4);}
.header h1{font-size:22px;font-weight:900;color:#1a1208;}
.header-sub{display:flex;align-items:center;justify-content:center;gap:10px;margin-top:4px;}
.header-sub p{font-size:12px;color:#3d2a08;}
/* عملة سويتش */
.cur-switch{display:flex;gap:3px;background:rgba(0,0,0,0.15);border-radius:999px;padding:3px;}
.cur-btn{padding:3px 10px;border-radius:999px;border:none;cursor:pointer;font-size:11px;font-weight:800;font-family:'Cairo',sans-serif;background:transparent;color:#3d2a08;transition:all 0.2s;}
.cur-btn.active{background:#1a1208;color:var(--gold-light);}
.page-header{background:linear-gradient(135deg,#c8963e,#e8b86d);padding:18px 20px;text-align:center;}
.page-header h2{font-size:21px;font-weight:900;color:#1a1208;}
.page-header p{font-size:13px;color:#3d2a08;margin-top:3px;}
.cat-bar{display:flex;gap:8px;padding:12px 16px;overflow-x:auto;background:var(--bg2);border-bottom:1px solid var(--border);scrollbar-width:none;}
.cat-bar::-webkit-scrollbar{display:none;}
.cat-btn{white-space:nowrap;padding:8px 16px;border-radius:999px;border:none;cursor:pointer;font-size:13px;font-family:'Cairo',sans-serif;font-weight:700;background:#2a2520;color:var(--muted);transition:all 0.2s;}
.cat-btn.active{background:var(--gold);color:#1a1208;}
.menu-page{padding:16px 16px 100px;}
.section-title{font-size:17px;font-weight:700;color:var(--gold-light);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.item-card{background:var(--bg3);border-radius:16px;margin-bottom:12px;overflow:hidden;border:1px solid var(--border);display:flex;align-items:center;transition:border-color 0.2s;}
.item-card.in-cart{border-color:var(--gold);}
.item-emoji{font-size:34px;padding:16px 10px;background:#161411;min-width:64px;text-align:center;}
.item-body{flex:1;padding:12px 14px;}
.item-name{font-size:15px;font-weight:700;margin-bottom:3px;}
.item-desc{font-size:12px;color:var(--dim);margin-bottom:8px;}
.item-footer{display:flex;justify-content:space-between;align-items:center;}
.item-price{font-size:13px;font-weight:800;color:var(--gold);line-height:1.5;}
.item-price small{display:block;font-size:10px;color:var(--dim);font-weight:600;}
.item-controls{display:flex;align-items:center;gap:8px;}
.qty-btn{width:30px;height:30px;border-radius:50%;border:none;cursor:pointer;font-size:18px;font-weight:700;display:flex;align-items:center;justify-content:center;font-family:'Cairo',sans-serif;}
.qty-btn.plus{background:var(--gold);color:#1a1208;}
.qty-btn.minus{background:#2a2520;color:var(--text);}
.qty-num{min-width:24px;text-align:center;font-weight:800;font-size:16px;}
#float-cart{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#c8963e,#e8b86d);color:#1a1208;border:none;border-radius:999px;padding:14px 28px;font-size:15px;font-weight:800;cursor:pointer;box-shadow:0 8px 30px rgba(200,150,62,0.5);display:none;align-items:center;gap:10px;font-family:'Cairo',sans-serif;z-index:100;max-width:340px;width:90%;justify-content:space-between;}
.cart-badge{background:#1a1208;color:var(--gold-light);border-radius:50%;width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;}
.form-wrap{padding:0 16px;}
.form-label{color:var(--muted);font-size:14px;margin-bottom:8px;display:block;margin-top:16px;}
.form-input{width:100%;background:var(--bg3);border:1px solid #3a3530;border-radius:12px;padding:12px 16px;font-size:15px;color:var(--text);font-family:'Cairo',sans-serif;direction:rtl;outline:none;}
.form-input:focus{border-color:var(--gold);}
textarea.form-input{min-height:80px;resize:none;}
select.form-input{appearance:none;}
.back-btn{background:none;border:none;color:var(--gold);font-size:15px;cursor:pointer;padding:14px 20px;font-family:'Cairo',sans-serif;font-weight:700;display:flex;align-items:center;gap:6px;}
.btn-primary{width:100%;background:linear-gradient(135deg,#c8963e,#e8b86d);border:none;border-radius:14px;padding:15px;font-size:16px;font-weight:800;color:#1a1208;cursor:pointer;font-family:'Cairo',sans-serif;margin-top:8px;}
.btn-secondary{width:100%;background:var(--bg3);border:2px solid #3a3530;border-radius:14px;padding:13px;font-size:14px;font-weight:700;color:var(--text);cursor:pointer;font-family:'Cairo',sans-serif;margin-top:8px;}
.btn-danger{background:#7a1a1a;border:none;border-radius:8px;padding:6px 12px;font-size:12px;color:#ffaaaa;cursor:pointer;font-family:'Cairo',sans-serif;}
.btn-sm{background:#1a3a2a;border:none;border-radius:8px;padding:6px 12px;font-size:12px;color:#aaffaa;cursor:pointer;font-family:'Cairo',sans-serif;}
.info-box{background:var(--bg3);border-radius:14px;padding:16px;margin:16px 0;border:1px solid var(--border);}
.info-box .row{display:flex;justify-content:space-between;padding:5px 0;font-size:14px;color:var(--muted);}
.info-box .total{display:flex;justify-content:space-between;padding-top:12px;border-top:1px solid var(--border);font-size:18px;font-weight:800;color:var(--gold-light);margin-top:8px;}
.cart-item{display:flex;align-items:center;background:var(--bg3);border-radius:12px;margin-bottom:8px;overflow:hidden;border:1px solid var(--border);}
.cart-item-emoji{font-size:26px;padding:12px 10px;background:#161411;min-width:54px;text-align:center;}
.cart-item-body{flex:1;padding:10px 12px;}
/* باقات الدفع */
.pay-tabs{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;}
.pay-tab{flex:1;min-width:80px;padding:10px 6px;border:none;border-radius:10px;cursor:pointer;font-family:'Cairo',sans-serif;font-weight:700;font-size:12px;transition:all 0.2s;background:#2a2520;color:var(--muted);}
.pay-tab.active{background:var(--gold);color:#1a1208;}
.pay-panel{display:none;}
.pay-panel.active{display:block;}
.steps-box{background:#1a1814;border-radius:14px;padding:16px;margin-bottom:16px;border:1px solid rgba(200,150,62,0.3);font-size:13px;line-height:2.2;color:var(--muted);}
.steps-box .title{color:var(--gold);font-weight:700;margin-bottom:4px;}
.verify-result{border-radius:12px;padding:14px;margin-bottom:12px;font-size:14px;text-align:center;display:none;}
.verify-result.ok{background:#0d2a1a;border:1px solid #2a7a4a;color:#4ade80;}
.verify-result.fail{background:#2a0d0d;border:1px solid #7a2a2a;color:#f87171;}
/* نجاح */
.success-page{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:32px;text-align:center;}
.success-icon{font-size:80px;margin-bottom:24px;animation:pop 0.4s ease;}
@keyframes pop{0%{transform:scale(0)}80%{transform:scale(1.1)}100%{transform:scale(1)}}
/* أدمن */
.admin-login{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:32px;text-align:center;}
.admin-section{background:var(--bg3);border-radius:16px;margin:12px 16px;border:1px solid var(--border);overflow:hidden;}
.admin-section-title{background:#2a2520;padding:13px 16px;font-weight:700;color:var(--gold-light);font-size:14px;display:flex;justify-content:space-between;align-items:center;}
.admin-field{padding:11px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.admin-field label{color:var(--muted);font-size:13px;min-width:85px;}
.admin-field input{flex:1;background:#161411;border:1px solid #3a3530;border-radius:8px;padding:8px 12px;font-size:14px;color:var(--text);font-family:'Cairo',sans-serif;direction:rtl;outline:none;}
.admin-field input:focus{border-color:var(--gold);}
.admin-item{padding:11px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.admin-item-info{flex:1;}
.admin-item-name{font-size:14px;font-weight:700;margin-bottom:2px;}
.admin-item-price{font-size:12px;color:var(--gold);}
.admin-cat-header{background:#1a1814;padding:9px 16px;font-size:13px;color:var(--gold);font-weight:700;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
/* بطاقة أسعار الصرف */
.rate-card{display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:1px solid var(--border);}
.rate-flag{font-size:28px;min-width:40px;text-align:center;}
.rate-info{flex:1;}
.rate-name{font-size:14px;font-weight:700;margin-bottom:4px;}
.rate-input-wrap{display:flex;align-items:center;gap:8px;}
.rate-input{background:#161411;border:1px solid #3a3530;border-radius:8px;padding:8px 12px;font-size:15px;font-weight:700;color:var(--gold-light);font-family:'Cairo',sans-serif;width:130px;direction:ltr;text-align:center;outline:none;}
.rate-input:focus{border-color:var(--gold);}
.rate-unit{color:var(--muted);font-size:12px;}
/* عرض أسعار الصرف للعميل */
.rates-banner{background:#1a1814;border-bottom:1px solid var(--border);padding:8px 16px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}
.rates-banner span{font-size:11px;color:var(--muted);}
.rates-banner strong{color:var(--gold-light);}
/* modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:200;display:none;align-items:center;justify-content:center;padding:20px;}
.modal-overlay.active{display:flex;}
.modal{background:var(--bg2);border-radius:20px;padding:22px;width:100%;max-width:400px;border:1px solid var(--border);}
.modal h3{font-size:18px;font-weight:800;color:var(--gold-light);margin-bottom:14px;}
.modal-btns{display:flex;gap:8px;margin-top:14px;}
.modal-btns button{flex:1;}
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:var(--gold);color:#1a1208;padding:12px 24px;border-radius:999px;font-weight:700;font-size:14px;z-index:300;opacity:0;transition:opacity 0.3s;pointer-events:none;white-space:nowrap;}

/* ===== NEW UI ===== */
.top-header-row{display:flex;justify-content:space-between;align-items:center;gap:10px;}
.logo-box{width:56px;height:56px;border-radius:16px;background:rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;font-size:28px;color:#1a1208;font-weight:900;overflow:hidden;}
.logo-box img{width:100%;height:100%;object-fit:cover;}
.lang-switch{background:rgba(0,0,0,0.15);padding:8px 12px;border-radius:999px;font-size:12px;font-weight:800;color:#1a1208;cursor:pointer;}
.social-links{display:flex;gap:8px;justify-content:center;margin-top:10px;}
.social-btn{width:34px;height:34px;border-radius:50%;background:#1a1208;color:var(--gold-light);display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:15px;font-weight:800;}
.hero-slider{position:relative;height:190px;overflow:hidden;margin:14px 16px;border-radius:20px;border:1px solid var(--border);}
.hero-slide{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity .6s;}
.hero-slide.active{opacity:1;}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.7),rgba(0,0,0,.2));}
.hero-caption{position:absolute;bottom:18px;right:18px;font-size:22px;font-weight:900;}
.search-wrap{padding:0 16px 12px;}
.search-box{display:flex;gap:10px;}
.search-input,.price-filter{background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:12px;color:var(--text);font-family:'Cairo',sans-serif;}
.search-input{flex:1;}
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);max-width:480px;width:100%;background:#161411;border-top:1px solid var(--border);display:flex;justify-content:space-around;padding:10px 0;z-index:120;}
.nav-btn{background:none;border:none;color:var(--muted);font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:4px;}
.nav-btn.active{color:var(--gold-light);}

</style>
</head>
<body>
<div class="app">

<!-- ===== منيو ===== -->
<div id="page-menu" class="page active">
  <div class="header">
    <div class="top-header-row">
      <div class="lang-switch" onclick="toggleLanguage()">AR | EN</div>
      <div class="logo-box" id="logo-box">🍽️</div>
      <div class="cur-switch" id="cur-switch">
        <button class="cur-btn active" onclick="setCurrency('SYP',this)">ل.س</button>
        <button class="cur-btn" onclick="setCurrency('USD',this)">$</button>
        <button class="cur-btn" onclick="setCurrency('TRY',this)">₺</button>
      </div>
    </div>

    <h1 id="rest-name-display" style="margin-top:10px">مطعم الجسري</h1>

    <div class="social-links">
      <a id="insta-link" class="social-btn" href="#" target="_blank">IG</a>
      <a id="facebook-link" class="social-btn" href="#" target="_blank">f</a>
    </div>

    <div class="header-sub">
      <p>اطلب من قائمتنا مباشرة</p>
    </div>
  </div>

  <div class="hero-slider" id="hero-slider"></div>

  <div class="rates-banner" id="rates-banner"></div>

  <div class="search-wrap">
    <div class="search-box">
      <input type="text" id="search-input" class="search-input" placeholder="ابحث عن صنف..." oninput="buildMenu()">
      <select id="price-filter" class="price-filter" onchange="buildMenu()">
        <option value="all">كل الأسعار</option>
        <option value="300">حتى 250</option>
        <option value="800">حتى 800</option>
        <option value="1200">حتى 1200</option>
      </select>
    </div>
  </div>

  <div class="cat-bar" id="cat-bar"></div>
  <div id="menu-content"></div>
  <button id="float-cart" onclick="goTo('page-cart')">
    <div class="cart-badge" id="cart-count">0</div>
    <span>عرض السلة</span>
    <span id="cart-total-float">0</span>
  </button>
</div>

<!-- ===== سلة ===== -->
<div id="page-cart" class="page">
  <div class="page-header"><h2>🛒 سلة الطلبات</h2><p id="cart-cur-label">بالليرة السورية</p></div>
  <button class="back-btn" onclick="goTo('page-menu')">← إضافة المزيد</button>
  <div class="form-wrap">
    <label class="form-label">🪑 رقم الطاولة</label>
    <input class="form-input" id="table-number" placeholder="أدخل رقم طاولتك" type="number">
    <label class="form-label">طلباتك</label>
    <div id="cart-items-list"></div>
    <label class="form-label">📝 ملاحظات (اختياري)</label>
    <textarea class="form-input" id="order-note" placeholder="مثال: بدون بصل..."></textarea>
    <div class="info-box">
      <div class="row"><span>عدد الأصناف</span><span id="cart-kinds">0</span></div>
      <div class="row" id="syp-row" style="display:none"><span>بالليرة السورية</span><span id="cart-syp">0</span></div>
      <div class="total"><span>المجموع</span><span id="cart-total-page">0</span></div>
    </div>
    <button class="btn-primary" onclick="goTo('page-payment')">💳 إتمام الطلب ←</button><button class="btn-secondary" onclick="clearCart()">🗑️ مسح السلة</button>
  </div>
</div>

<!-- ===== دفع ===== -->
<div id="page-payment" class="page">
  <div class="page-header">
    <h2>📱 إرسال الطلب</h2>
    <p>سيتم تحويلك مباشرة إلى واتساب المطعم</p>
  </div>

  <button class="back-btn" onclick="goTo('page-cart')">← العودة للسلة</button>

  <div class="form-wrap">
    <div class="info-box">
      <div style="font-size:14px;line-height:2;color:var(--muted)">
        ✅ سيتم إرسال الطلب عبر واتساب مباشرة<br>
        ✅ بيانات الطلب ستبقى محفوظة حتى يتم الإرسال
      </div>
    </div>

    <button class="btn-primary" onclick="sendWhatsApp()">📱 إرسال الطلب عبر واتساب</button>

    <!--
    طرق الدفع معطلة حالياً:
    - شام كاش
    - سيريتل كاش
    - API KEY
    -->
  </div>
</div>

<!-- ===== نجاح ===== -->
<div id="page-success" class="page">
  <div class="success-page">
    <div class="success-icon">✅</div>
    <div style="font-size:24px;font-weight:900;color:var(--gold-light);margin-bottom:10px;">تم إرسال طلبك!</div>
    <div style="color:var(--muted);font-size:15px;line-height:1.8;margin-bottom:28px;">وصل طلبك للمطعم 🍽️<br>سيتم تحضيره قريباً</div>
    <div class="info-box" id="success-summary" style="width:100%;margin-bottom:24px;"></div>
    <button class="btn-primary" onclick="resetOrder()" style="max-width:300px;width:100%">🔄 طلب جديد</button>
  </div>
</div>

<!-- ===== أدمن لوجين ===== -->
<div id="page-admin-login" class="page">
  <div class="admin-login">
    <div style="font-size:56px;margin-bottom:14px;">🔐</div>
    <h2 style="font-size:20px;font-weight:900;color:var(--gold-light);margin-bottom:22px;">لوحة تحكم المطعم</h2>
    <div style="width:100%;max-width:300px">
      <input class="form-input" id="admin-pass" type="password" placeholder="كلمة المرور"
        onkeydown="if(event.key==='Enter')checkAdminPass()">
      <button class="btn-primary" onclick="checkAdminPass()" style="margin-top:10px">دخول ←</button>
      <button class="btn-secondary" onclick="goTo('page-menu')">← العودة للمنيو</button>
      <p id="pass-error" style="color:#f87171;text-align:center;margin-top:10px;font-size:14px;display:none">❌ كلمة المرور خاطئة</p>
    </div>
  </div>
</div>

<!-- ===== لوحة التحكم ===== -->
<div id="page-admin" class="page">
  <div class="page-header"><h2>⚙️ لوحة التحكم</h2><p>إدارة المطعم والقائمة</p></div>
  <button class="back-btn" onclick="goTo('page-menu')">← العودة للمنيو</button>

  <!-- أسعار الصرف -->
  <div class="admin-section">
    <div class="admin-section-title">💱 أسعار الصرف اليومية</div>
    <div class="rate-card">
      <div class="rate-flag">🇺🇸</div>
      <div class="rate-info">
        <div class="rate-name">الدولار الأمريكي</div>
        <div class="rate-input-wrap">
          <span style="color:var(--muted);font-size:13px">1 $ =</span>
          <input class="rate-input" id="rate-usd" type="number" placeholder="13000">
          <span class="rate-unit">ل.س</span>
        </div>
      </div>
    </div>
    <div class="rate-card">
      <div class="rate-flag">🇹🇷</div>
      <div class="rate-info">
        <div class="rate-name">الليرة التركية</div>
        <div class="rate-input-wrap">
          <span style="color:var(--muted);font-size:13px">1 ₺ =</span>
          <input class="rate-input" id="rate-try" type="number" placeholder="380">
          <span class="rate-unit">ل.س</span>
        </div>
      </div>
    </div>
    <div style="padding:12px 16px">
      <button class="btn-primary" onclick="saveRates()">💾 حفظ أسعار الصرف</button>
    </div>
  </div>

  <!-- إعدادات المطعم -->
  <div class="admin-section">
    <div class="admin-section-title">🏪 إعدادات المطعم</div>
    <div class="admin-field"><label>اسم المطعم</label><input id="cfg-name"></div>
    <div class="admin-field"><label>واتساب</label><input id="cfg-whatsapp" dir="ltr"></div>
    <div class="admin-field"><label>شام كاش</label><input id="cfg-shamcash" dir="ltr"></div>
    <div class="admin-field"><label>سيريتل كاش</label><input id="cfg-syriatel" dir="ltr" placeholder="رقم الهاتف"></div>
    
    <div class="admin-field"><label>رابط إنستا</label><input id="cfg-instagram"></div>
    <div class="admin-field"><label>رابط فيسبوك</label><input id="cfg-facebook"></div>
    <div class="admin-field"><label>رابط اللوقو</label><input id="cfg-logo"></div>
